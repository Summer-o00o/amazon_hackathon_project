# Copy to .env and fill in real values. Never commit .env.

# Redis (optional, defaults: localhost:6379)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Nova / Bedrock
# NOVA_ENDPOINT=
# NOVA_REGION=us-east-1
# NOVA_API_KEY=

# Google Places API (required for place search)
# GOOGLE_PLACES_API_KEY=

# Real Estate API
# REALESTATE_API_BASE_URL=
# REALESTATE_API_KEY=

# Image storage path (optional, default: ./data/images)
# IMAGE_STORAGE_PATH=./data/images
